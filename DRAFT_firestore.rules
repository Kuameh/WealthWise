rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Holdings collection
    match /holdings/{holdingId} {
      function isValidHolding(data) {
        return data.ticker is string && data.ticker.size() <= 12 &&
               data.marketType in ['US', 'GSE', 'ETF'] &&
               data.shares is number && data.shares > 0 &&
               data.averageCost is number && data.averageCost > 0 &&
               data.userId == request.auth.uid;
      }

      allow get: if isOwner(resource.data.userId) && isValidId(holdingId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(holdingId) && 
                      isValidHolding(request.resource.data) &&
                      request.resource.data.keys().hasAll(['ticker', 'marketType', 'shares', 'averageCost', 'userId']) &&
                      request.resource.data.keys().size() >= 5;

      allow update: if isOwner(resource.data.userId) &&
                      isValidHolding(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.ticker == resource.data.ticker &&
                      request.resource.data.marketType == resource.data.marketType;

      allow delete: if isOwner(resource.data.userId);
    }
  }
}
